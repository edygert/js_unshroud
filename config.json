{
  "_comment": "js_unshroud Configuration - All available options with defaults",

  "enableConsole": true,
  "enableNetwork": true,
  "enableStorage": false,
  "enableWebSocket": true,
  "enableTimer": false,
  "enableError": true,
  "enableDOM": false,
  "enableFingerprinting": false,
  "enableObjectTracking": false,
