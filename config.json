    "encoding": {
      "enableAtobBtoa": false,
      "enableFromCharCode": true,
      "enableURIEncoding": false
    }
  },

  "_artifactCollectionComment": "Artifact collection configuration - saves file artifacts to disk for forensic analysis. Artifacts are saved to ./artifacts/<session-id>/ by default. pageSnapshot captures both initial (after page load) and final (before tool exit) HTML states for DOM manipulation analysis.",
