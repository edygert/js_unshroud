  "artifactDirectory": "./artifacts",
  "artifactTypes": {
    "pageSnapshot": true,
    "downloads": false,
    "codeExecution": false,
    "encoding": false,
    "cryptojs": false,
    "clipboard": false,
    "workers": false,
    "iframes": false
  },
  "maxArtifactSize": 10485760,

